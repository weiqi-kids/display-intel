{"id": "unknown-2026-05-11-006", "date": "2026-05-11", "time_tags": {"year": 2026, "quarter": "Q2", "month": 5, "week": 20, "weekday": "Mon"}, "entities": {"companies": [], "customers": [], "suppliers": []}, "topics": ["earnings"], "sentiment": {"label": "neutral", "score": 0.0, "keywords": []}, "importance": {"score": 0.75, "reasons": ["涉及財報"]}, "title": "Qisda sees recovery driven by AI and semiconductors, expects profit rebound through 2026", "content": "Qisda said its operations began to recover in the first quarter of 2026 after profits bottomed out in 2025, with chairman Peter Chen saying visibility for the second and third quarters is now better than in the first quarter. Chen expects revenue and earnings to return to normal in 2026 as AI and semiconductors continue to reshape the group's direction.", "sources": [{"name": "digitimes_display", "url": "https://www.digitimes.com/news/a20260511PD206/qisda-2026-semiconductors-profit-materials.html", "type": "rss"}]}
{"id": "unknown-2026-05-11-007", "date": "2026-05-11", "time_tags": {"year": 2026, "quarter": "Q2", "month": 5, "week": 20, "weekday": "Mon"}, "entities": {"companies": [], "customers": [], "suppliers": []}, "topics": ["mini_led", "earnings"], "sentiment": {"label": "neutral", "score": 0.0, "keywords": ["[否定]growth", "[否定]loss", "weak"]}, "importance": {"score": 0.75, "reasons": ["涉及財報"]}, "title": "Ennostar sees 2Q26 rebound on stronger component demand", "content": "Ennostar said its core losses narrowed significantly in the first quarter of 2026 from the previous quarter, despite the seasonally weak period for the industry, and expects a marked recovery in both revenue and shipments starting in the second quarter of 2026, driven by stronger demand for components and emerging growth in Micro LED technology.", "sources": [{"name": "digitimes_display", "url": "https://www.digitimes.com/news/a20260511PD223/ennostar-demand-revenue-2026-shipments.html", "type": "rss"}]}
{"id": "samsung_elec-2026-05-11-008", "date": "2026-05-11", "time_tags": {"year": 2026, "quarter": "Q2", "month": 5, "week": 20, "weekday": "Mon"}, "entities": {"companies": ["samsung_elec"], "customers": [], "suppliers": []}, "topics": [], "sentiment": {"label": "neutral", "score": 0.0, "keywords": []}, "importance": {"score": 0.5, "reasons": []}, "title": "AMD's 2nm defection to Samsung dents TSMC's AI grip", "content": "The AI semiconductor supply chain is showing unexpected signs of a shift, with TSMC's long-held dominance in the foundry market beginning to loosen. US chipmakers are increasingly engaging with Samsung Electronics and Intel as alternative suppliers, and AMD has already handed its 2nm order to Samsung.", "sources": [{"name": "digitimes_display", "url": "https://www.digitimes.com/news/a20260511PD215/samsung-tsmc-amd-2nm-supply-chain.html", "type": "rss"}]}
{"id": "unknown-2026-05-11-009", "date": "2026-05-11", "time_tags": {"year": 2026, "quarter": "Q2", "month": 5, "week": 20, "weekday": "Mon"}, "entities": {"companies": [], "customers": [], "suppliers": []}, "topics": ["earnings"], "sentiment": {"label": "neutral", "score": 0.0, "keywords": []}, "importance": {"score": 0.75, "reasons": ["涉及財報"]}, "title": "Trans-Sun Materials rides AI server wave with profit surge", "content": "Trans-Sun Materials Technology posted broad-based gains in the first quarter of 2026, with consolidated revenue rising 28.66% year on year to NT$379 million (US$12.07 million) and net profit attributable to the parent surging 66.34% to NT$26 million, yielding earnings per share of NT$1.07. The maker of electronic functional materials credited the performance to accelerating demand for high-performance computing infrastructure tied to the expansion of AI workloads.", "sources": [{"name": "digitimes_display", "url": "https://www.digitimes.com/news/a20260511PD218/materials-demand-profit-high-end-ai-server.html", "type": "rss"}]}
