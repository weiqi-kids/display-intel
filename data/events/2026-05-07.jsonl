{"id": "csot-2026-05-07-009", "date": "2026-05-07", "time_tags": {"year": 2026, "quarter": "Q2", "month": 5, "week": 19, "weekday": "Thu"}, "entities": {"companies": ["csot", "tcl"], "customers": ["tcl"], "suppliers": ["csot"]}, "topics": ["oled_penetration"], "sentiment": {"label": "neutral", "score": 0.0, "keywords": []}, "importance": {"score": 0.9, "reasons": ["多公司提及", "供應鏈上下游同時提及"]}, "title": "TCL CSOT demonstrates a 1700PPI Real-RGB 2.24\" AMOLED display for AR applications", "content": "<p>TCL CSOT is showing a 2.24\" 1700 PPI Real-RGB G-OLED display. This is the highest density such display that TCL has shown to date, improving on its <a href=\"https://www.oled-info.com/tcl-csot-shows-new-oled-display-prototypes\">previous 1,512 PPI AMOLED display showed in 2025</a>.</p><div class=\"align-center\">\n  \n  <a href=\"https://www.oled-info.com/sites/default/files/2026-05/TCL-CSOT-1700PPI-G-OLED-SID-DW-2026.jpg\" target=\"_blank\">\n    \n    <img loading=\"lazy\" src=\"https://www.oled-info.com/", "sources": [{"name": "oled_info", "url": "https://www.oled-info.com/tcl-csot-demonstrates-1700ppi-real-rgb-224-amoled-display-ar-applications", "type": "rss"}]}
{"id": "samsung_elec-2026-05-07-010", "date": "2026-05-07", "time_tags": {"year": 2026, "quarter": "Q2", "month": 5, "week": 19, "weekday": "Thu"}, "entities": {"companies": ["samsung_elec"], "customers": [], "suppliers": []}, "topics": ["it_panel_demand"], "sentiment": {"label": "positive", "score": 0.5, "keywords": ["strong demand"]}, "importance": {"score": 0.5, "reasons": []}, "title": "Taiwan freezes trading in MediaTek as AI chip rally pushes valuation past US$165 billion", "content": "Taiwan's stock exchange placed MediaTek &mdash; the chip designer behind silicon used in Samsung phones, Chromebooks, and a growing share of AI hardware &mdash; under trading restrictions from May 7 through May 20 after its market value surged past NT$5 trillion (approx. US$165 billion) on strong demand for its custom AI chips. The Financial Supervisory Commission said it would review the rules that triggered the move.", "sources": [{"name": "digitimes_display", "url": "https://www.digitimes.com/news/a20260507PD244/mediatek-market-tse-revenue-asic.html", "type": "rss"}]}
