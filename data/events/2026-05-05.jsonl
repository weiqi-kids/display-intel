{"id": "samsung_elec-2026-05-05-015", "date": "2026-05-05", "time_tags": {"year": 2026, "quarter": "Q2", "month": 5, "week": 19, "weekday": "Tue"}, "entities": {"companies": ["samsung_elec"], "customers": [], "suppliers": []}, "topics": [], "sentiment": {"label": "neutral", "score": 0.0, "keywords": []}, "importance": {"score": 0.5, "reasons": []}, "title": "Tesla AI5 dual sourcing may not mean equal weight for Samsung", "content": "Tesla CEO Elon Musk has confirmed that the company's in-house AI5 chip has completed design tape-out and entered a critical pre-production validation stage. The move has drawn renewed attention from supply chains in Taiwan and South Korea as Tesla builds a scalable computing infrastructure for vehicles, AI training systems, and humanoid robots.", "sources": [{"name": "digitimes_display", "url": "https://www.digitimes.com/news/a20260505PD229/tesla-chips-production-samsung.html", "type": "rss"}]}
{"id": "tcl-2026-05-05-016", "date": "2026-05-05", "time_tags": {"year": 2026, "quarter": "Q2", "month": 5, "week": 19, "weekday": "Tue"}, "entities": {"companies": ["tcl"], "customers": [], "suppliers": []}, "topics": [], "sentiment": {"label": "negative", "score": -0.5, "keywords": ["pressure"]}, "importance": {"score": 0.5, "reasons": []}, "title": "TCL reportedly in talks to sell majority stake in India display plant", "content": "China's TCL Electronics is reportedly in advanced discussions to sell a majority stake in its Indian display manufacturing business. The move underscores accelerating localization pressure on foreign electronics firms in India and the ongoing restructuring of Chinese supply chain presence in the country.", "sources": [{"name": "digitimes_display", "url": "https://www.digitimes.com/news/a20260505VL210/tcl-display-localization-plant-manufacturing.html", "type": "rss"}]}
